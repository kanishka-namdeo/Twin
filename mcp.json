{
    "mcpServers": {
        "Prisma": {
            "url": "https://mcp.prisma.io/mcp"
        },
        "vercel": {
            "url": "https://mcp.vercel.com"
        },
        "neo4j": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "neo4j-mcpserver"
            ],
            "env": {
                "NEO4J_URI": "neo4j://127.0.0.1:7687",
                "NEO4J_USER": "neo4j",
                "NEO4J_PASSWORD": "password",
                "NEO4J_DATABASE": "research",
                "NEO4J_READ_ONLY": "false"
            }
        },
        "chakra-ui": {
            "command": "npx",
            "args": [
                "-y",
                "@chakra-ui/react-mcp"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest",
                "--headless=true",
                "--isolated=true",
                "--experimentalPageIdRouting=true",
                "--experimentalMemory=true",
                "--experimentalScreencast=true",
                "--experimentalVision=true",
                "--experimentalStructuredContent=true",
                "--experimentalIncludeAllPages=true",
                "--categoryExperimentalThirdParty=true"
            ]
        },
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest",
                "--vision",
                "--allow-unrestricted-file-access",
                "--no-sandbox",
                "--cdp-endpoint=http://localhost:9222"
            ]
        },
        "ESLint": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "@eslint/mcp@latest"
            ]
        },
        "mcp-deepwiki": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-deepwiki@latest"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "codebase-memory-mcp": {
            "command": "C:/Users/kanis/AppData/Local/Programs/codebase-memory-mcp/codebase-memory-mcp.exe"
        }
    }
}
